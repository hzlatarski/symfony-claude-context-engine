# Per-project config
sources.yaml

# Python
__pycache__/
*.pyc
.venv/

# Runtime state
scripts/state.json
scripts/last-flush.json
scripts/flush.log
scripts/compile.log
scripts/session-flush-*
scripts/flush-context-*

# Reports
reports/

# Knowledge base content (LLM-generated, project-specific)
knowledge/
daily/

# Vector database — NEVER commit embeddings; they contain raw indexed content
# and grow fast. Binary SQLite + parquet files won't diff usefully anyway.
chroma_db/
chroma/
*.chroma/
**/chroma.sqlite3

# But test fixtures named daily/* are checked in
!tests/fixtures/daily/
!tests/fixtures/daily/**

# Work in progress (project-specific)
wip.md

# Source drop zone contents (project-specific, not the dirs themselves)
sources/articles/*.md
sources/notes/*.md
sources/pdfs/*.pdf

# uv lock (regenerated by uv sync)
scripts/uv.lock

# Claude Code local settings
.claude/settings.local.json

# OS files
.DS_Store
Thumbs.db

.obsidian/
.worktrees/
